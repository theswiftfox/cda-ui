{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cda-ui",
  "identifier": "com.cda.ui",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173/ui/",
    "beforeBuildCommand": "pnpm build -- --config vite.config.tauri.ts",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CDA - Classic Diagnostic Adapter",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/128x128.png",
      "icons/256x256.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwMTU5NzA5RDEzRjc1QUYKUldTdmRUL1JDWmNWNExCTCtDL2ZMc0k0S1NsdnpZNzVHZlpMblliVVdoYzdXTVMwUlhoTzllN1IK",
      "endpoints": [
        "https://github.com/theswiftfox/cda-ui/releases/latest/download/latest.json"
      ]
    }
  }
}
